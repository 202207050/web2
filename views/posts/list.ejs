<div class="my-5">
    <h1 class="text-center mb-5">게시판</h1>
    <table id="tbl" class="table table-striped table-hover"></table>
    <div>
        <button id="prev" class="btn btn-primary btn-sm px-3">이전</button>
        <span id="span_page">1/10</span>
        <button id="next" class="btn btn-primary btn-sm px-3">다음</button>
    </div>
    <script id="temp" type="text/x-handlebars-template">
        <tbody>
            {{#each .}}
            <tr>
                <td>{{ID}}</td>
                <td>{{TITLE}}</td>
                <td>{{SNAME}}{{WRITER}}</td>
                <td>{{REG_DATE}}</td>
            </tr>
            {{/each}}
        </tbody>
    </script>
</div>
<script>
    let page=1;
    let size=5;
    getList();

    $("#next").on("click", function(){
        page++;
        getList();
    });

    $("#prev").on("click", function(){
        page--;
        getList();
    });

    function getList(){
        $.ajax({
            type:"get",
            url:"posts/list.json",
            data:{page, size},
            success:function(data){
                console.log(data);
                const temp=Handlebars.compile($("#temp").html());
                $("#tbl").html(temp(data.list));
                $("#span_page").html(`${page}`);

                if(page==1) $("#prev").attr("disabled", true);
                else $("#prev").attr("disabled", false);
                
                const last = Math.ceil(data.count/size);
                $("#span_page").html(`${page}/${last}`);

                if(page==last) $("#next").attr("disabled", true);
                else $("#next").attr("disabled", false);
            }
        });
    }
</script>