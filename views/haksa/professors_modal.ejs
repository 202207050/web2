<!-- Button trigger modal -->
<button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#staticBackdrop">
  교수검색
</button>

<!-- Modal -->
<div class="modal fade" id="staticBackdrop" data-bs-backdrop="static" data-bs-keyboard="false" tabindex="-1" aria-labelledby="staticBackdropLabel" aria-hidden="true">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header">
        <h1 class="modal-title fs-5" id="staticBackdropLabel">교수검색</h1>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body">
        <table id="tbl" class="table table-striped table-hover"></table> 
    <script id="temp" type="text/x-handlebars-template">
        <tbody>
            {{#each .}}
                <tr>
                    <td>{{PCODE}}</td>
                    <td><a href="{{PCODE}}">{{PNAME}}</a></td>
                    <td>{{DEPT}}</td>
                </tr>
            {{/each}}
        </tbody>
    </script>
    </div>
    <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
        </div>
    </div>
    </div>
</div>
<script>
    function getList(){
        $.ajax({
            type:"get",
            url:"/haksa/pro/list.json",
            success:function(data){
                console.log(data)
                const temp=Handlebars.compile($("#temp").html());
                $("#tbl").html(temp(data));
            }
        })
    }
    //교수 이름을 클릭한 경우
    $("#tbl").on("click", "a", function(e){
        e.preventDefault();
        const pcode = $(this).attr("href");
        //alert(pcode);
        $(frm.pcode).val(pcode);
        $("#staticBackdrop").modal("hide");
    });

// 모달이 열릴 때 getList() 호출 추가
$("#staticBackdrop").on("shown.bs.modal", function(){
    getList();
});

    </script>
